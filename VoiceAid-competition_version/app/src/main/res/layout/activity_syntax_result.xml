<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    android:orientation="vertical"
    tools:context=".SyntaxResultActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:text="句法能力测评结果"
        android:textColor="@color/black"
        android:textSize="27sp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="20dp">

            <!-- 题目详细信息表格 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/white"
                android:orientation="vertical"
                android:padding="10dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="题目详情"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:paddingBottom="10dp" />

                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="500dp">

                        <TableLayout
                            android:id="@+id/question_detail_table"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:stretchColumns="*">

                            <!-- 表头 -->
                            <TableRow
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="#F0F0F0">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="测试阶段"
                                    android:textStyle="bold"
                                    android:gravity="center"
                                    android:padding="8dp"
                                    android:textSize="14sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="题号"
                                    android:textStyle="bold"
                                    android:gravity="center"
                                    android:padding="8dp"
                                    android:textSize="14sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="例句"
                                    android:textStyle="bold"
                                    android:gravity="center"
                                    android:padding="8dp"
                                    android:textSize="14sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="测试结果"
                                    android:textStyle="bold"
                                    android:gravity="center"
                                    android:padding="8dp"
                                    android:textSize="14sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="对应测试语"
                                    android:textStyle="bold"
                                    android:gravity="center"
                                    android:padding="8dp"
                                    android:textSize="14sp" />

                            </TableRow>

                        </TableLayout>

                    </ScrollView>

            </LinearLayout>

            <!-- 评估建议 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/white"
                android:orientation="vertical"
                android:padding="15dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="评估建议"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:paddingBottom="10dp" />

                <TextView
                    android:id="@+id/tv_3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="评估建议内容"
                    android:textSize="16sp"
                    android:lineSpacingExtra="8dp" />

                <!-- 需要重点关注的能力 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="15dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="1. 【需要重点关注的能力】"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:paddingBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="这些语言能力还没有发展出来，需要重点关注。"
                        android:textSize="16sp"
                        android:paddingBottom="8dp" />

                    <LinearLayout
                        android:id="@+id/weakness_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <TextView
                            android:id="@+id/weakness_1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="1. 复杂句理解"
                            android:textSize="16sp"
                            android:padding="5dp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- 不稳定的能力 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="15dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="2. 【不稳定的能力】"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:paddingBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="有些语言能力已经发展出来，但是不够稳定，我们可以多去引导，在家多做语言示范。"
                        android:textSize="16sp"
                        android:paddingBottom="8dp" />

                    <LinearLayout
                        android:id="@+id/unstable_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <TextView
                            android:id="@+id/unstable_1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="1. 复合句理解"
                            android:textSize="16sp"
                            android:padding="5dp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <Button
        android:id="@+id/back"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/blue_button"
        android:text="返回"
        android:textSize="20sp" />

</LinearLayout>
<!-- activity_main.xml -->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    android:fillViewport="true"
    android:paddingTop="10dp"
    tools:context="login.Loginactivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 标题 -->
        <TextView
            android:id="@+id/tv_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="评测结果"
            android:textColor="@color/black"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- （一）记录表 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="（一）记录表"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="8dp"
            android:background="@android:color/darker_gray" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" />

        <!-- （二）评估结果 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="（二）评估结果"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="start"
            android:textColor="@color/black"
            android:textSize="16sp" />

        <LinearLayout
            android:id="@+id/extra_a_results"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/table"
            android:orientation="vertical"
            android:padding="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:paddingBottom="4dp"
                android:text="1. 声母总正确率"
                android:textColor="@color/black"
                android:textSize="16sp" />

            <TableLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stretchColumns="1,3,5,7">
                <!-- 声母表格 -->
                <TableRow>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="6dp"
                        android:text="b"
                        android:textColor="@color/black" />

                    <EditText
                        android:id="@+id/initial_b"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/table"
                        android:padding="6dp"
                        android:singleLine="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="6dp"
                        android:text="p"
                        android:textColor="@color/black" />

                    <EditText
                        android:id="@+id/initial_p"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/table"
                        android:padding="6dp"
                        android:singleLine="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="6dp"
                        android:text="m"
                        android:textColor="@color/black" />

                    <EditText
                        android:id="@+id/initial_m"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/table"
                        android:padding="6dp"
                        android:singleLine="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="6dp"
                        android:text="f"
                        android:textColor="@color/black" />

                    <EditText
                        android:id="@+id/initial_f"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/table"
                        android:padding="6dp"
                        android:singleLine="true" />
                </TableRow>

                <TableRow>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="6dp"
                        android:text="d"
                        android:textColor="@color/black" />

                    <EditText
                        android:id="@+id/initial_d"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/table"
                        android:padding="6dp"
                        android:singleLine="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="6dp"
                        android:text="t"
                        android:textColor="@color/black" />

                    <EditText
                        android:id="@+id/initial_t"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/table"
                        android:padding="6dp"
                        android:singleLine="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="6dp"
                        android:text="n"
                        android:textColor="@color/black" />

                    <EditText
                        android:id="@+id/initial_n"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/table"
                        android:padding="6dp"
                        android:singleLine="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="6dp"
                        android:text="l"
                        android:textColor="@color/black" />

                    <EditText
                        android:id="@+id/initial_l"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/table"
                        android:padding="6dp"
                        android:singleLine="true" />
                </TableRow>

                <TableRow>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="6dp"
                        android:text="g"
                        android:textColor="@color/black" />

                    <EditText
                        android:id="@+id/initial_g"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/table"
                        android:padding="6dp"
                        android:singleLine="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="6dp"
                        android:text="k"
                        android:textColor="@color/black" />

                    <EditText
                        android:id="@+id/initial_k"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/table"
                        android:padding="6dp"
                        android:singleLine="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="6dp"
                        android:text="h"
                        android:textColor="@color/black" />

                    <EditText
                        android:id="@+id/initial_h"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/table"
                        android:padding="6dp"
                        android:singleLine="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="6dp"
                        android:text="j"
                        android:textColor="@color/black" />

                    <EditText
                        android:id="@+id/initial_j"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/table"
                        android:padding="6dp"
                        android:singleLine="true" />
                </TableRow>

                <TableRow>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="6dp"
                        android:text="q"
                        android:textColor="@color/black" />

                    <EditText
                        android:id="@+id/initial_q"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/table"
                        android:padding="6dp"
                        android:singleLine="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="6dp"
                        android:text="x"
                        android:textColor="@color/black" />

                    <EditText
                        android:id="@+id/initial_x"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/table"
                        android:padding="6dp"
                        android:singleLine="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="6dp"
                        android:text="zh"
                        android:textColor="@color/black" />

                    <EditText
                        android:id="@+id/initial_zh"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/table"
                        android:padding="6dp"
                        android:singleLine="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="6dp"
                        android:text="ch"
                        android:textColor="@color/black" />

                    <EditText
                        android:id="@+id/initial_ch"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/table"
                        android:padding="6dp"
                        android:singleLine="true" />
                </TableRow>

                <TableRow>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="6dp"
                        android:text="sh"
                        android:textColor="@color/black" />

                    <EditText
                        android:id="@+id/initial_sh"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/table"
                        android:padding="6dp"
                        android:singleLine="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="6dp"
                        android:text="r"
                        android:textColor="@color/black" />

                    <EditText
                        android:id="@+id/initial_r"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/table"
                        android:padding="6dp"
                        android:singleLine="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="6dp"
                        android:text="z"
                        android:textColor="@color/black" />

                    <EditText
                        android:id="@+id/initial_z"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/table"
                        android:padding="6dp"
                        android:singleLine="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="6dp"
                        android:text="c"
                        android:textColor="@color/black" />

                    <EditText
                        android:id="@+id/initial_c"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/table"
                        android:padding="6dp"
                        android:singleLine="true" />
                </TableRow>
            </TableLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:paddingBottom="4dp"
                android:text="2. 韵母正确率"
                android:textColor="@color/black"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/extra_a_vowel_accuracy"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:background="@drawable/table"
                android:gravity="top"
                android:hint="填写韵母正确率"
                android:padding="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3. 语音清晰度等级："
                    android:textColor="@color/black"
                    android:textSize="16sp" />

                <EditText
                    android:id="@+id/extra_a_speech_clarity"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/table"
                    android:padding="6dp"
                    android:singleLine="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  声母正确率："
                    android:textColor="@color/black"
                    android:textSize="16sp" />

                <EditText
                    android:id="@+id/extra_a_initial_accuracy"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/table"
                    android:padding="6dp"
                    android:singleLine="true" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:paddingBottom="4dp"
                android:text="4. 诊断（直接勾选）"
                android:textColor="@color/black"
                android:textSize="16sp" />

            <CheckBox
                android:id="@+id/extra_a_diag_normal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="正常发展中/正常语言" />

            <CheckBox
                android:id="@+id/extra_a_diag_phonology"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="构音/音韵异常" />

            <CheckBox
                android:id="@+id/extra_a_diag_tone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="声调异常" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/extra_a_suggestions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/table"
            android:orientation="vertical"
            android:padding="12dp"
            android:visibility="gone">

            <CheckBox
                android:id="@+id/extra_a_suggest_none"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="不需转介/音韵治疗" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <CheckBox
                    android:id="@+id/extra_a_suggest_follow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="定期追踪与观察" />

                <EditText
                    android:id="@+id/extra_a_follow_months"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/table"
                    android:padding="6dp"
                    android:singleLine="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="个月后复查" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <CheckBox
                    android:id="@+id/extra_a_suggest_trad"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="传统构音治疗法: 治疗频次:" />

                <EditText
                    android:id="@+id/extra_a_trad_freq"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/table"
                    android:padding="6dp"
                    android:singleLine="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="次/周" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <CheckBox
                    android:id="@+id/extra_a_suggest_phono"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="音韵疗程治疗法: 治疗频次:" />

                <EditText
                    android:id="@+id/extra_a_phono_freq"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/table"
                    android:padding="6dp"
                    android:singleLine="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="次/周" />
            </LinearLayout>

            <CheckBox
                android:id="@+id/extra_a_suggest_more"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="需做进一步检查" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/pl_suggestions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/table"
            android:orientation="vertical"
            android:padding="12dp"
            android:visibility="gone">

            <RadioGroup
                android:id="@+id/pl_option_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/pl_option1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="6dp"
                    android:paddingBottom="8dp"
                    android:text="选项1" />

                <RadioButton
                    android:id="@+id/pl_option2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="6dp"
                    android:text="选项2" />
            </RadioGroup>

            <Button
                android:id="@+id/pl_save_button"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/btn"
                android:text="返回" />
        </LinearLayout>

        <!-- 返回按钮置底 -->
        <Button
            android:id="@+id/back"
            android:layout_width="157dp"
            android:layout_height="87dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/blue_button"
            android:text="返回"
            app:backgroundTint="#A4E2A0" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
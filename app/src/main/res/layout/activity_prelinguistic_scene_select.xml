<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F8F8"
    android:orientation="vertical"
    android:padding="20dp"
    tools:context=".PrelinguisticSceneSelectActivity">

    <TextView
        android:id="@+id/text_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginTop="30dp"
        android:layout_marginBottom="40dp"
        android:fontFamily="@font/zcool_kuaile"
        android:text="选择场景"
        android:textColor="#0F172A"
        android:textSize="30sp" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#FFFFFF"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <Button
                android:id="@+id/btn_scene_a"
                android:layout_width="match_parent"
                android:layout_height="93dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="#008A7C"
                android:fontFamily="@font/zcool_kuaile"
                android:text="A 吹泡泡场景"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                app:cornerRadius="12dp" />

            <Button
                android:id="@+id/btn_scene_b"
                android:layout_width="match_parent"
                android:layout_height="95dp"
                android:backgroundTint="#008A7C"
                android:fontFamily="@font/zcool_kuaile"
                android:text="B 玩球场景"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                app:cornerRadius="12dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    android:orientation="vertical"
    tools:context=".SyntaxResultActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:text="鍙ユ硶鑳藉姏娴嬭瘎缁撴灉"
        android:textColor="@color/black"
        android:textSize="27sp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="20dp">

            <!-- 棰樼洰璇︾粏淇℃伅琛ㄦ牸 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/white"
                android:orientation="vertical"
                android:padding="10dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="棰樼洰璇︽儏"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:paddingBottom="10dp" />

                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="500dp">

                        <TableLayout
                            android:id="@+id/question_detail_table"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:stretchColumns="*">

                            <!-- 琛ㄥご -->
                            <TableRow
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="#F0F0F0">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="娴嬭瘯闃舵"
                                    android:textStyle="bold"
                                    android:gravity="center"
                                    android:padding="8dp"
                                    android:textSize="14sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="棰樺彿"
                                    android:textStyle="bold"
                                    android:gravity="center"
                                    android:padding="8dp"
                                    android:textSize="14sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="渚嬪彞"
                                    android:textStyle="bold"
                                    android:gravity="center"
                                    android:padding="8dp"
                                    android:textSize="14sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="娴嬭瘯缁撴灉"
                                    android:textStyle="bold"
                                    android:gravity="center"
                                    android:padding="8dp"
                                    android:textSize="14sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="对应语法点"
                                    android:textStyle="bold"
                                    android:gravity="center"
                                    android:padding="8dp"
                                    android:textSize="14sp" />

                            </TableRow>

                        </TableLayout>

                    </ScrollView>

            </LinearLayout>

            <!-- 璇勪及寤鸿 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/white"
                android:orientation="vertical"
                android:padding="15dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="璇勪及寤鸿"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:paddingBottom="10dp" />

                <TextView
                    android:id="@+id/tv_3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="璇勪及寤鸿鍐呭"
                    android:textSize="16sp"
                    android:lineSpacingExtra="8dp" />

                <!-- 闇€瑕侀噸鐐瑰叧娉ㄧ殑鑳藉姏 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="15dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="1. 重点关注能力"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:paddingBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="这些语法能力尚不稳定，建议重点关注。"
                        android:textSize="16sp"
                        android:paddingBottom="8dp" />

                    <LinearLayout
                        android:id="@+id/weakness_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <TextView
                            android:id="@+id/weakness_1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="1. 示例能力"
                            android:textSize="16sp"
                            android:padding="5dp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- 涓嶇ǔ瀹氱殑鑳藉姏 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="15dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="2. 不稳定能力"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:paddingBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="这些能力已有出现，但稳定性不足，建议持续训练。"
                        android:textSize="16sp"
                        android:paddingBottom="8dp" />

                    <LinearLayout
                        android:id="@+id/unstable_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <TextView
                            android:id="@+id/unstable_1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="1. 示例能力"
                            android:textSize="16sp"
                            android:padding="5dp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingBottom="20dp">

        <Button
            android:id="@+id/back"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginEnd="12dp"
            android:layout_weight="1"
            android:background="@drawable/blue_button"
            android:text="返回"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btn_generate_intervention"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:background="@drawable/green_button"
            android:text="生成干预报告"
            android:textSize="18sp" />
    </LinearLayout>

</LinearLayout>

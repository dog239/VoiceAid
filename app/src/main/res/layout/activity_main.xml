<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    android:orientation="horizontal"
    android:paddingBottom="80dp"
    tools:context="login.Loginactivity">


    <TextView
        android:id="@+id/tv_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/green_blue"
        android:gravity="center"
        android:paddingTop="20dp"
        android:text="学前儿童汉语评测"
        android:textColor="@color/black"
        android:textSize="30sp"
        app:layout_constraintBottom_toTopOf="@id/btn_new1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="spread_inside" />

    <LinearLayout
        android:id="@+id/btn_new1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/btn_old1"
        app:layout_constraintTop_toBottomOf="@id/tv_1">

        <TextView
            android:id="@+id/new1_no"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_weight="1"
            android:background="@drawable/startbuttonleft"
            android:paddingVertical="20dp"
            android:text="1"
            android:textAlignment="center"
            android:textSize="25sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="74dp"
            android:layout_weight="3"
            android:background="@drawable/startbuttonright"
            android:paddingVertical="20dp"
            android:paddingRight="20dp"
            android:text="新评测"
            android:textAlignment="center"
            android:textSize="25sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btn_old1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/btn_old2"
        app:layout_constraintTop_toBottomOf="@id/btn_new1">

        <TextView
            android:id="@+id/old1_no"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_weight="1"
            android:background="@drawable/startbuttonleft"
            android:paddingVertical="20dp"
            android:text="1"
            android:textAlignment="center"
            android:textSize="25sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="74dp"
            android:layout_weight="3"
            android:background="@drawable/startbuttonright"
            android:paddingVertical="20dp"
            android:paddingRight="20dp"
            android:text="本机评测"
            android:textAlignment="center"
            android:textSize="25sp" />
    </LinearLayout>


    <LinearLayout
        android:id="@+id/btn_old2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/btn_all"
        app:layout_constraintTop_toBottomOf="@id/btn_old1">

        <TextView
            android:id="@+id/old2_no"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_weight="1"
            android:background="@drawable/startbuttonleft"
            android:paddingVertical="20dp"
            android:text="1"
            android:textAlignment="center"
            android:textSize="25sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="74dp"
            android:layout_weight="3"
            android:background="@drawable/startbuttonright"
            android:paddingVertical="20dp"
            android:paddingRight="20dp"
            android:text="个人评测"
            android:textAlignment="center"
            android:textSize="25sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btn_all"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/btn_record"
        app:layout_constraintTop_toBottomOf="@id/btn_old2">

        <TextView
            android:id="@+id/all_no"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_weight="1"
            android:background="@drawable/startbuttonleft"
            android:paddingVertical="20dp"
            android:text="1"
            android:textAlignment="center"
            android:textSize="25sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="74dp"
            android:layout_weight="3"
            android:background="@drawable/startbuttonright"
            android:paddingVertical="20dp"
            android:paddingRight="20dp"
            android:text="所有测评"
            android:textAlignment="center"
            android:textSize="25sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btn_record"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/btn_changeModule"
        app:layout_constraintTop_toBottomOf="@id/btn_all">

        <TextView
            android:id="@+id/record_no"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_weight="1"
            android:background="@drawable/startbuttonleft"
            android:paddingVertical="20dp"
            android:text="1"
            android:textAlignment="center"
            android:textSize="25sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="74dp"
            android:layout_weight="3"
            android:background="@drawable/startbuttonright"
            android:paddingVertical="20dp"
            android:paddingRight="20dp"
            android:text="试音"
            android:textAlignment="center"
            android:textSize="25sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btn_changeModule"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/btn_logout"
        app:layout_constraintTop_toBottomOf="@id/btn_record">

        <TextView
            android:id="@+id/changeModule_no"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_weight="1"
            android:background="@drawable/startbuttonleft"
            android:paddingVertical="20dp"
            android:text="1"
            android:textAlignment="center"
            android:textSize="25sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="74dp"
            android:layout_weight="3"
            android:background="@drawable/startbuttonright"
            android:paddingVertical="20dp"
            android:paddingRight="20dp"
            android:text="测评模块修改"
            android:textAlignment="center"
            android:textSize="25sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btn_logout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/btn_delete"
        app:layout_constraintTop_toBottomOf="@id/btn_changeModule"

        >

        <TextView
            android:id="@+id/logout_no"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_weight="1"
            android:background="@drawable/startbuttonleft"
            android:paddingVertical="20dp"
            android:text="1"
            android:textAlignment="center"
            android:textSize="25sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="74dp"
            android:layout_weight="3"
            android:background="@drawable/startbuttonright"
            android:paddingVertical="20dp"
            android:paddingRight="20dp"
            android:text="退出登录"
            android:textAlignment="center"
            android:textSize="25sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btn_delete"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_logout">

        <TextView
            android:id="@+id/delete_no"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_weight="1"
            android:background="@drawable/startbuttonleft"
            android:paddingVertical="20dp"
            android:text="1"
            android:textAlignment="center"
            android:textSize="25sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="74dp"
            android:layout_weight="3"
            android:background="@drawable/startbuttonright"
            android:paddingVertical="20dp"
            android:paddingRight="20dp"
            android:text="注销用户"
            android:textAlignment="center"
            android:textSize="25sp" />
    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>



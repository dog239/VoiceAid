<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F8F8"
    android:orientation="vertical"
    android:paddingTop="10dp"
    tools:context="login.Loginactivity"
    tools:ignore="ExtraText">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="643dp"
        android:layout_gravity="center_vertical"
        android:layout_marginTop="100dp"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/ll2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_3"
                android:layout_width="match_parent"
                android:layout_height="125dp"
                android:gravity="center"
                android:text="账号注销"
                android:textColor="#0F172A"
                android:textSize="28sp"
                android:fontFamily="@font/zcool_kuaile" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginTop="10dp"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <EditText
                        android:id="@+id/et_tel_or_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/cage"
                        android:hint="手机号/邮箱"
                        android:inputType="text"
                        android:padding="12dp"
                        android:textColor="#0F172A"
                        android:textColorHint="#94A3B8"
                        android:textSize="16sp" />

                    <LinearLayout
                        android:id="@+id/lll"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <EditText
                            android:id="@+id/et_capcha"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/cage"
                            android:hint="验证码"
                            android:inputType="text"
                            android:padding="12dp"
                            android:textColor="#0F172A"
                            android:textColorHint="#94A3B8"
                            android:textSize="16sp" />

                        <Button
                            android:id="@+id/btn_getcapcha"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:backgroundTint="#E2E8F0"
                            android:fontFamily="@font/zcool_kuaile"
                            android:padding="12dp"
                            android:text="获取验证码"
                            android:textColor="#008A7C"
                            android:textSize="14sp"
                            app:cornerRadius="8dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="154dp"
                android:layout_marginTop="24dp"
                android:orientation="horizontal"
                android:padding="20dp">

                <Button
                    android:id="@+id/btn_sure"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_gravity="center"
                    android:layout_marginRight="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="#008A7C"
                    android:fontFamily="@font/zcool_kuaile"
                    android:text="注销"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    app:cornerRadius="12dp" />

                <Button
                    android:id="@+id/btn_back"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_gravity="center"
                    android:layout_marginLeft="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="#E2E8F0"
                    android:fontFamily="@font/zcool_kuaile"
                    android:text="返回"
                    android:textColor="#64748B"
                    android:textSize="18sp"
                    app:cornerRadius="12dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_plan_stage_card_middle"
    android:orientation="vertical"
    android:paddingTop="10dp"
    tools:context="login.Loginactivity">

    <TextView
        android:id="@+id/tv_1"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:gravity="center"
        android:text="词汇表达评测结果"
        android:textColor="@color/black"
        android:textSize="30sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp"
        android:orientation="vertical"
        android:padding="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"

            >

            <TextView
                android:id="@+id/tv_w1_11"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/table_topleft"
                android:gravity="center"
                android:text="题号"
                android:textColor="@color/black"
                android:textSize="30sp" />

            <TextView
                android:id="@+id/tv_w1_12"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="2dp"
                android:layout_weight="2"
                android:background="@drawable/table"
                android:gravity="center"
                android:text="目标词"
                android:textColor="@color/black"
                android:textSize="30sp" />

            <TextView
                android:id="@+id/tv_w1_13"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="1dp"
                android:layout_weight="1"
                android:background="@drawable/table"
                android:gravity="center"
                android:text="结果"
                android:textColor="@color/black"
                android:textSize="30sp" />

            <TextView
                android:id="@+id/tv_w1_14"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="1dp"
                android:layout_weight="1"
                android:background="@drawable/table_topright"
                android:gravity="center"
                android:text="录音"
                android:textColor="@color/black"
                android:textSize="30sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_w1_21"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginRight="1dp"
                android:layout_weight="1"
                android:background="@drawable/table"
                android:gravity="center"
                android:text="1"
                android:textColor="@color/black"
                android:textSize="30sp" />

            <TextView
                android:id="@+id/tv_w1_22"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="1dp"
                android:layout_weight="2"
                android:background="@drawable/table"
                android:gravity="center"
                android:text="衣服/上衣"
                android:textColor="@color/black"
                android:textSize="30sp" />

            <ImageView
                android:id="@+id/iv_w1_23"
                android:layout_width="0dp"
                android:layout_height="43.65dp"
                android:layout_marginLeft="1dp"
                android:layout_weight="1"
                android:background="@drawable/table"
                android:scaleType="fitCenter" />

            <ImageView
                android:id="@+id/iv_w1_24"
                android:layout_width="0dp"
                android:layout_height="43.65dp"
                android:layout_marginLeft="1dp"
                android:layout_weight="1"

                android:background="@drawable/table" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_w1_31"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginRight="1dp"
                android:layout_weight="1"
                android:background="@drawable/table"
                android:gravity="center"
                android:text="2"
                android:textColor="@color/white"
                android:textSize="30sp" />

            <TextView
                android:id="@+id/tv_w1_32"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="1dp"
                android:layout_weight="2"
                android:background="@drawable/table"
                android:gravity="center"
                android:text="马"
                android:textColor="@color/white"
                android:textSize="30sp" />

            <ImageView
                android:id="@+id/iv_w1_33"
                android:layout_width="0dp"
                android:layout_height="43.65dp"
                android:layout_marginLeft="1dp"
                android:layout_weight="1"
                android:background="@drawable/table"
                android:scaleType="fitCenter" />

            <ImageView
                android:id="@+id/iv_w1_34"
                android:layout_width="0dp"
                android:layout_height="43.65dp"
                android:layout_marginLeft="1dp"
                android:layout_weight="1"
                android:background="@drawable/table" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_w1_41"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginRight="1dp"
                android:layout_weight="1"
                android:background="@drawable/table"
                android:gravity="center"
                android:text="3"
                android:textColor="@color/white"
                android:textSize="30sp" />

            <TextView
                android:id="@+id/tv_w1_42"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="1dp"
                android:layout_weight="2"
                android:background="@drawable/table"
                android:gravity="center"
                android:text="绳子/绳结"
                android:textColor="@color/white"
                android:textSize="30sp" />

            <ImageView
                android:id="@+id/iv_w1_43"
                android:layout_width="0dp"
                android:layout_height="43.65dp"
                android:layout_marginLeft="1dp"
                android:layout_weight="1"
                android:background="@drawable/table"
                android:scaleType="fitCenter" />

            <ImageView
                android:id="@+id/iv_w1_44"
                android:layout_width="0dp"
                android:layout_height="43.65dp"
                android:layout_marginLeft="1dp"
                android:layout_weight="1"

                android:background="@drawable/table" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_w1_51"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginRight="1dp"
                android:layout_weight="1"
                android:background="@drawable/table"
                android:gravity="center"
                android:text="4"
                android:textColor="@color/white"
                android:textSize="30sp" />

            <TextView
                android:id="@+id/tv_w1_52"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="1dp"
                android:layout_weight="2"
                android:background="@drawable/table"
                android:gravity="center"
                android:text="船"
                android:textColor="@color/white"
                android:textSize="30sp" />

            <ImageView
                android:id="@+id/iv_w1_53"
                android:layout_width="0dp"
                android:layout_height="43.65dp"
                android:layout_marginLeft="1dp"
                android:layout_weight="1"
                android:background="@drawable/table"
                android:scaleType="fitCenter" />

            <ImageView
                android:id="@+id/iv_w1_54"
                android:layout_width="0dp"
                android:layout_height="43.65dp"
                android:layout_marginLeft="1dp"
                android:layout_weight="1"

                android:background="@drawable/table" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_w1_61"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginRight="1dp"
                android:layout_weight="1"
                android:background="@drawable/table_bottomleft"
                android:gravity="center"
                android:text="5"
                android:textColor="@color/white"
                android:textSize="30sp" />

            <TextView
                android:id="@+id/tv_w1_62"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="1dp"
                android:layout_weight="2"
                android:background="@drawable/table"
                android:gravity="center"
                android:text="勺子"
                android:textColor="@color/white"
                android:textSize="30sp" />

            <ImageView
                android:id="@+id/iv_w1_63"
                android:layout_width="0dp"
                android:layout_height="43.65dp"
                android:layout_marginLeft="1dp"
                android:layout_weight="1"
                android:background="@drawable/table"
                android:scaleType="fitCenter" />

            <ImageView
                android:id="@+id/iv_w1_64"
                android:layout_width="0dp"
                android:layout_height="43.65dp"
                android:layout_marginLeft="1dp"
                android:layout_weight="1"

                android:background="@drawable/table_bottomright" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tv_w1acc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:text="最终正确率为"
        android:textColor="@color/pink"
        android:textSize="30sp" />

    <Button
        android:id="@+id/btn_w1back"
        android:layout_width="143dp"
        android:layout_height="130dp"
        android:layout_gravity="center"
        android:layout_margin="20dp"
        android:background="@drawable/blue_button"

        android:text="返回"
        android:textSize="24sp"
        app:backgroundTint="#7282D5" />
</LinearLayout>
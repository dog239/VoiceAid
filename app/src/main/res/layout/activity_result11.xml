                    </TableRow>
                    <TableRow>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center" android:padding="6dp" android:text="g" android:textColor="@color/black" />
                        <EditText android:id="@+id/initial_g" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/table" android:padding="6dp" android:singleLine="true" />

                    android:textStyle="bold" />

                <TableLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:stretchColumns="1,3,5">
                    <TableRow>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center" android:padding="6dp" android:text="an" android:textColor="@color/black" />
                        <EditText android:id="@+id/vowel_an" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/table" android:padding="6dp" android:singleLine="true" />

                    </TableRow>
                    <TableRow>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center" android:padding="6dp" android:text="iang" android:textColor="@color/black" />
                        <EditText android:id="@+id/vowel_iang" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/table" android:padding="6dp" android:singleLine="true" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center" android:padding="6dp" android:text="ing" android:textColor="@color/black" />
                        <EditText android:id="@+id/vowel_ing" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/table" android:padding="6dp" android:singleLine="true" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center" android:padding="6dp" android:text="uan" android:textColor="@color/black" />
                        <EditText android:id="@+id/vowel_uan" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/table" android:padding="6dp" android:singleLine="true" />
                    </TableRow>
                    <TableRow>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center" android:padding="6dp" android:text="uen" android:textColor="@color/black" />
                        <EditText android:id="@+id/vowel_uen" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/table" android:padding="6dp" android:singleLine="true" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center" android:padding="6dp" android:text="uang" android:textColor="@color/black" />
                        <EditText android:id="@+id/vowel_uang" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/table" android:padding="6dp" android:singleLine="true" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center" android:padding="6dp" android:text="ong" android:textColor="@color/black" />
                        <EditText android:id="@+id/vowel_ong" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/table" android:padding="6dp" android:singleLine="true" />
                    </TableRow>
                    <TableRow>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center" android:padding="6dp" android:text="üan" android:textColor="@color/black" />
                        <EditText android:id="@+id/vowel_uan_umlaut" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/table" android:padding="6dp" android:singleLine="true" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center" android:padding="6dp" android:text="ün" android:textColor="@color/black" />
                        <EditText android:id="@+id/vowel_un" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/table" android:padding="6dp" android:singleLine="true" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center" android:padding="6dp" android:text="iong" android:textColor="@color/black" />
                        <EditText android:id="@+id/vowel_iong" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/table" android:padding="6dp" android:singleLine="true" />
                    </TableRow>
                </TableLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="错误韵母："
                        android:textColor="@color/black"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/vowel_error_list"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/table"
                        android:padding="6dp"
                        android:singleLine="false" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3. 语音清晰度等级："
                        android:textColor="@color/black"
                        android:textSize="16sp" />

                    <EditText
                        android:id="@+id/extra_a_speech_clarity"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/table"
                        android:padding="6dp"
                        android:singleLine="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  声母正确率："
                        android:textColor="@color/black"
                        android:textSize="16sp" />

                    <EditText
                        android:id="@+id/extra_a_initial_accuracy"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/table"
                        android:padding="6dp"
                        android:singleLine="true" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="12dp"
                    android:paddingBottom="4dp"
                    android:text="4. 诊断（直接勾选）"
                    android:textColor="@color/black"
                    android:textSize="16sp" />

                <CheckBox
                    android:id="@+id/extra_a_diag_normal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="正常发展中/正常语言" />

                <CheckBox
                    android:id="@+id/extra_a_diag_phonology"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="构音/音韵异常" />

                <CheckBox
                    android:id="@+id/extra_a_diag_tone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="声调异常" />

            </LinearLayout>

            <!-- （三）评估建议 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="（三）评估建议"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="start"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/extra_a_suggestions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/table"
                android:orientation="vertical"
                android:padding="12dp"
                android:visibility="gone">

                <CheckBox
                    android:id="@+id/extra_a_suggest_none"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="不需转介/音韵治疗" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <CheckBox
                        android:id="@+id/extra_a_suggest_follow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="定期追踪与观察" />

                    <EditText
                        android:id="@+id/extra_a_follow_months"
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:background="@drawable/table"
                        android:padding="6dp"
                        android:singleLine="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="个月后复查" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <CheckBox
                        android:id="@+id/extra_a_suggest_trad"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="传统构音治疗法: 治疗频次:" />

                    <EditText
                        android:id="@+id/extra_a_trad_freq"
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:background="@drawable/table"
                        android:padding="6dp"
                        android:singleLine="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="次/周" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <CheckBox
                        android:id="@+id/extra_a_suggest_phono"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="音韵疗程治疗法: 治疗频次:" />

                    <EditText
                        android:id="@+id/extra_a_phono_freq"
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:background="@drawable/table"
                        android:padding="6dp"
                        android:singleLine="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="次/周" />
                </LinearLayout>

                <CheckBox
                    android:id="@+id/extra_a_suggest_more"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="需做进一步检查" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/pl_suggestions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/table"
                android:orientation="vertical"
                android:padding="12dp"
                android:visibility="gone">

                <RadioGroup
                    android:id="@+id/pl_option_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/pl_option1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="6dp"
                        android:paddingBottom="8dp"
                        android:text="选项1" />

                    <RadioButton
                        android:id="@+id/pl_option2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="6dp"
                        android:text="选项2" />
                </RadioGroup>

                <Button
                    android:id="@+id/pl_save_button"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/btn"
                    android:text="返回" />
            </LinearLayout>

            <!-- 隐藏旧的返回按钮，保留ID防止Java报错 -->
            <Button
                android:id="@+id/back"
                android:layout_width="157dp"
                android:layout_height="87dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/blue_button"
                android:text="返回"
                android:visibility="gone"
                app:backgroundTint="#A4E2A0" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- 3. 底部 Bottom Action Bar (仿照 activity_articulation_result.xml) -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_generate_plan"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="#008A7C"
            android:text="生成干预方案"
            android:textColor="#FFFFFF"
            app:cornerRadius="12dp"
            app:icon="@android:drawable/ic_menu_edit"
            app:iconGravity="textStart" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

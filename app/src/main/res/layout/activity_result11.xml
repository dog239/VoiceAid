<!-- activity_main.xml -->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:paddingTop="10dp"
    android:background="@drawable/bg"
    tools:context="login.Loginactivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 标题 -->
        <TextView
            android:id="@+id/tv_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="评测结果"
            android:textColor="@color/black"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- （一）记录表 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="（一）记录表"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="8dp"
            android:background="@android:color/darker_gray" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" />

        <!-- （二）评估结果 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="（二）评估结果"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black" />

        <TextView
            android:id="@+id/tv_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="start"
            android:textColor="@color/black"
            android:textSize="16sp" />

        <LinearLayout
            android:id="@+id/extra_a_results"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            android:padding="12dp"
            android:visibility="gone"
            android:background="@drawable/table">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="构音A结果"
                android:textSize="18sp"
                android:textColor="@color/black"
                android:padding="4dp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. 声母正确率"
                android:textSize="16sp"
                android:textColor="@color/black"
                android:paddingTop="8dp"
                android:paddingBottom="4dp" />

            <TableLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stretchColumns="1,3,5,7">
                <!-- 声母表格 -->
                <TableRow>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="b" android:padding="6dp" android:gravity="center" android:textColor="@color/black" />
                    <EditText android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/table" android:padding="6dp" android:singleLine="true" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="p" android:padding="6dp" android:gravity="center" android:textColor="@color/black" />
                    <EditText android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/table" android:padding="6dp" android:singleLine="true" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="m" android:padding="6dp" android:gravity="center" android:textColor="@color/black" />
                    <EditText android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/table" android:padding="6dp" android:singleLine="true" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="f" android:padding="6dp" android:gravity="center" android:textColor="@color/black" />
                    <EditText android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/table" android:padding="6dp" android:singleLine="true" />
                </TableRow>
                <TableRow>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="d" android:padding="6dp" android:gravity="center" android:textColor="@color/black" />
                    <EditText android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/table" android:padding="6dp" android:singleLine="true" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="t" android:padding="6dp" android:gravity="center" android:textColor="@color/black" />
                    <EditText android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/table" android:padding="6dp" android:singleLine="true" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="n" android:padding="6dp" android:gravity="center" android:textColor="@color/black" />
                    <EditText android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/table" android:padding="6dp" android:singleLine="true" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="l" android:padding="6dp" android:gravity="center" android:textColor="@color/black" />
                    <EditText android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/table" android:padding="6dp" android:singleLine="true" />
                </TableRow>
                <TableRow>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="g" android:padding="6dp" android:gravity="center" android:textColor="@color/black" />
                    <EditText android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/table" android:padding="6dp" android:singleLine="true" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="k" android:padding="6dp" android:gravity="center" android:textColor="@color/black" />
                    <EditText android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/table" android:padding="6dp" android:singleLine="true" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="h" android:padding="6dp" android:gravity="center" android:textColor="@color/black" />
                    <EditText android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/table" android:padding="6dp" android:singleLine="true" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="j" android:padding="6dp" android:gravity="center" android:textColor="@color/black" />
                    <EditText android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/table" android:padding="6dp" android:singleLine="true" />
                </TableRow>
                <TableRow>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="q" android:padding="6dp" android:gravity="center" android:textColor="@color/black" />
                    <EditText android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/table" android:padding="6dp" android:singleLine="true" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="x" android:padding="6dp" android:gravity="center" android:textColor="@color/black" />
                    <EditText android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/table" android:padding="6dp" android:singleLine="true" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="zh" android:padding="6dp" android:gravity="center" android:textColor="@color/black" />
                    <EditText android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/table" android:padding="6dp" android:singleLine="true" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ch" android:padding="6dp" android:gravity="center" android:textColor="@color/black" />
                    <EditText android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/table" android:padding="6dp" android:singleLine="true" />
                </TableRow>
                <TableRow>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="sh" android:padding="6dp" android:gravity="center" android:textColor="@color/black" />
                    <EditText android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/table" android:padding="6dp" android:singleLine="true" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="r" android:padding="6dp" android:gravity="center" android:textColor="@color/black" />
                    <EditText android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/table" android:padding="6dp" android:singleLine="true" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="z" android:padding="6dp" android:gravity="center" android:textColor="@color/black" />
                    <EditText android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/table" android:padding="6dp" android:singleLine="true" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="c" android:padding="6dp" android:gravity="center" android:textColor="@color/black" />
                    <EditText android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/table" android:padding="6dp" android:singleLine="true" />
                </TableRow>
            </TableLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="2. 韵母正确率"
                android:textSize="16sp"
                android:textColor="@color/black"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />

            <EditText
                android:id="@+id/extra_a_vowel_accuracy"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:gravity="top"
                android:background="@drawable/table"
                android:padding="8dp"
                android:hint="填写韵母正确率" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3. 语音清晰度等级："
                    android:textSize="16sp"
                    android:textColor="@color/black" />
                <EditText
                    android:id="@+id/extra_a_speech_clarity"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/table"
                    android:padding="6dp"
                    android:singleLine="true" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  声母正确率："
                    android:textSize="16sp"
                    android:textColor="@color/black" />
                <EditText
                    android:id="@+id/extra_a_initial_accuracy"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/table"
                    android:padding="6dp"
                    android:singleLine="true" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="4. 诊断（直接勾选）"
                android:textSize="16sp"
                android:textColor="@color/black"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />

            <CheckBox
                android:id="@+id/extra_a_diag_normal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="正常发展中/正常语言" />
            <CheckBox
                android:id="@+id/extra_a_diag_phonology"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="构音/音韵异常" />
            <CheckBox
                android:id="@+id/extra_a_diag_tone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="声调异常" />

        </LinearLayout>

        <!-- （三）评估建议 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="（三）评估建议"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black" />

        <LinearLayout
            android:id="@+id/extra_a_suggestions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp"
            android:padding="12dp"
            android:visibility="gone"
            android:background="@drawable/table">

            <CheckBox
                android:id="@+id/extra_a_suggest_none"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="不需转介/音韵治疗" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <CheckBox
                    android:id="@+id/extra_a_suggest_follow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="定期追踪与观察" />
                <EditText
                    android:id="@+id/extra_a_follow_months"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/table"
                    android:padding="6dp"
                    android:singleLine="true" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="个月后复查" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <CheckBox
                    android:id="@+id/extra_a_suggest_trad"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="传统构音治疗法: 治疗频次:" />
                <EditText
                    android:id="@+id/extra_a_trad_freq"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/table"
                    android:padding="6dp"
                    android:singleLine="true" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="次/周" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <CheckBox
                    android:id="@+id/extra_a_suggest_phono"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="音韵疗程治疗法: 治疗频次:" />
                <EditText
                    android:id="@+id/extra_a_phono_freq"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/table"
                    android:padding="6dp"
                    android:singleLine="true" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="次/周" />
            </LinearLayout>
            <CheckBox
                android:id="@+id/extra_a_suggest_more"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="需做进一步检查" />
        </LinearLayout>

        <!-- 返回按钮置底 -->
        <Button
            android:id="@+id/back"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="24dp"
            android:text="返回"
            android:background="@drawable/cage" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>


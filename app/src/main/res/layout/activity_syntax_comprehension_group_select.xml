<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    android:gravity="center"
    android:orientation="vertical"
    tools:context=".SyntaxComprehensionGroupSelectActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:text="句法理解 - 选择组别"
        android:textColor="@color/black"
        android:textSize="27sp" />

    <LinearLayout
        android:layout_width="270dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="30dp"
        android:layout_marginTop="30dp"
        android:gravity="center"
        android:orientation="vertical">

        <Button
            android:id="@+id/btn_group1"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginBottom="15dp"
            android:background="@drawable/blue_button"
            android:text="第一组"
            android:textSize="30sp"
            app:backgroundTint="#B3EBAF" />

        <Button
            android:id="@+id/btn_group2"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginBottom="15dp"
            android:background="@drawable/blue_button"
            android:text="第二组"
            android:textSize="30sp"
            app:backgroundTint="#FAE799" />

        <Button
            android:id="@+id/btn_group3"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginBottom="15dp"
            android:background="@drawable/blue_button"
            android:text="第三组"
            android:textSize="30sp"
            app:backgroundTint="#FBCED8" />

        <Button
            android:id="@+id/btn_group4"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:background="@drawable/blue_button"
            android:text="第四组"
            android:textSize="30sp"
            app:backgroundTint="#ADEEFF" />

    </LinearLayout>

</LinearLayout>

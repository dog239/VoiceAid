<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F8F8"
    android:paddingHorizontal="20dp"
    android:paddingTop="10dp"
    android:fillViewport="true"
    tools:context=".login.RegisterActivity">

    <LinearLayout
        android:id="@+id/ll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/zcool_kuaile"
            android:gravity="center"
            android:paddingVertical="30dp"
            android:text="平台注册"
            android:textColor="#0F172A"
            android:textSize="34sp" />

        <!-- 注册卡片 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="15dp"
            android:layout_marginTop="5dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp"
            app:strokeColor="#E2E8F0"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="8dp"
                        android:src="@android:drawable/ic_menu_edit"
                        app:tint="#008A7C" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="填写注册信息"
                        android:textColor="#0F172A"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- 手机号/邮箱 -->
                <EditText
                    android:id="@+id/et_tel_or_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/cage"
                    android:hint="手机号/邮箱"
                    android:inputType="text"
                    android:padding="16dp"
                    android:textColor="#0F172A"
                    android:textColorHint="#64748B"
                    android:textSize="16sp" />

                <!-- 验证码行 -->
                <LinearLayout
                    android:id="@+id/lll"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/et_capcha"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/cage"
                        android:hint="验证码"
                        android:inputType="text"
                        android:padding="16dp"
                        android:textColor="#0F172A"
                        android:textColorHint="#64748B"
                        android:textSize="16sp" />

                    <Button
                        android:id="@+id/btn_getcapcha"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:backgroundTint="#E2E8F0"
                        android:fontFamily="@font/zcool_kuaile"
                        android:padding="12dp"
                        android:text="获取验证码"
                        android:textColor="#008A7C"
                        android:textSize="14sp"
                        app:cornerRadius="12dp" />
                </LinearLayout>

                <!-- 用户名 -->
                <EditText
                    android:id="@+id/et_regname"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/cage"
                    android:hint="用户名"
                    android:inputType="text"
                    android:padding="16dp"
                    android:textColor="#0F172A"
                    android:textColorHint="#64748B"
                    android:textSize="16sp" />

                <!-- 密码 -->
                <EditText
                    android:id="@+id/et_regcode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/cage"
                    android:hint="密码"
                    android:inputType="textPassword"
                    android:padding="16dp"
                    android:textColor="#0F172A"
                    android:textColorHint="#64748B"
                    android:textSize="16sp" />

                <!-- 确认密码 -->
                <EditText
                    android:id="@+id/et_regcheck"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/cage"
                    android:hint="再次确认密码"
                    android:inputType="textPassword"
                    android:padding="16dp"
                    android:textColor="#0F172A"
                    android:textColorHint="#64748B"
                    android:textSize="16sp" />

                <!-- 测评模块选择 (修改为6个模块，但保持原有CheckBox ID不变) -->
                <LinearLayout
                    android:id="@+id/chooseTable"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/black_dash"
                    android:orientation="vertical"
                    android:padding="15dp"
                    android:visibility="visible">

                    <TextView
                        android:id="@+id/tv_2"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:background="#008A7C"
                        android:gravity="center"
                        android:text="测评模块选择"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:fontFamily="@font/zcool_kuaile" />

                    <!-- 第一行：构音、前语言、词汇 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:orientation="horizontal">

                        <CheckBox
                            android:id="@+id/pronounciation"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="构音"
                            android:textColor="#0F172A"
                            android:textSize="14sp" />

                        <CheckBox
                            android:id="@+id/prelinguistic"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="前语言"
                            android:textColor="#0F172A"
                            android:textSize="14sp" />

                        <CheckBox
                            android:id="@+id/word"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="词汇"
                            android:textColor="#0F172A"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <!-- 第二行：句法表达、句法理解、社交 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <CheckBox
                            android:id="@+id/grammar"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="句法表达"
                            android:textColor="#0F172A"
                            android:textSize="14sp" />

                        <CheckBox
                            android:id="@+id/narrator"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="句法理解"
                            android:textColor="#0F172A"
                            android:textSize="14sp" />

                        <CheckBox
                            android:id="@+id/social"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="社交"
                            android:textColor="#0F172A"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <!-- 提示文字 -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="（可多选，根据实际情况选择需要评估的方面）"
                        android:textColor="#64748B"
                        android:textSize="12sp"
                        android:gravity="center" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 按钮区域 - 完全保持原样，未做任何修改 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="15dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="20dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_sure"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:backgroundTint="#008A7C"
                android:fontFamily="@font/zcool_kuaile"
                android:paddingVertical="12dp"
                android:text="确定"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                app:cornerRadius="12dp" />

            <Button
                android:id="@+id/btn_back"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:backgroundTint="#E2E8F0"
                android:fontFamily="@font/zcool_kuaile"
                android:paddingVertical="12dp"
                android:text="返回"
                android:textColor="#64748B"
                android:textSize="18sp"
                app:cornerRadius="12dp" />
        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>

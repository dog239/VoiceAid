<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingTop="0dp"
    android:paddingBottom="10dp"
    android:paddingHorizontal="0dp"
    android:background="@drawable/bg"
    android:id="@+id/root"
    android:orientation="vertical">



    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl2"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:visibility="gone"
        >

        <TextView
            android:id="@+id/pleasewait"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:textSize="30sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:visibility="visible"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        >


        <TextView
            android:id="@+id/tv_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingTop="10dp"
            android:text="学前儿童汉语评测"
            android:textColor="@color/black"
            android:textSize="27sp"
            app:layout_constraintBottom_toTopOf="@id/wd"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="spread_inside"
            android:background="#00B4C1"
             />

        <LinearLayout
        android:id="@+id/wd"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/tv_1"
        app:layout_constraintBottom_toTopOf="@id/pn"
        >
        <TextView
            android:id="@+id/tv_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="词汇"
            android:textColor="@color/black"
            android:textSize="25dp"
            android:background="@color/warm_blue"
            />
        <LinearLayout
            android:layout_marginHorizontal="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="1dp"
            android:layout_marginTop="10dp"
            >
            <Button
                android:id="@+id/btn_wordTest1"
                android:layout_width="0dp"
                android:layout_weight="2"
                android:layout_height="wrap_content"
                android:text="词汇表达"
                android:layout_gravity="center"
                android:layout_marginRight="1dp"
                android:background="@drawable/btn_left"
            />
            <Button
                android:id="@+id/btn_wordResult1"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="评测结果"
                android:layout_gravity="center"
                android:layout_marginLeft="1dp"
                android:background="@drawable/btn_right"
            />
        </LinearLayout>
        <LinearLayout
            android:layout_marginHorizontal="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="1dp"
            >
            <Button
                android:id="@+id/btn_wordTest2"
                android:layout_width="0dp"
                android:layout_weight="2"
                android:layout_height="wrap_content"
                android:text="词汇理解"
                android:layout_gravity="center"
                android:layout_marginRight="1dp"
                android:background="@drawable/btn_left"
                />
            <Button
                android:id="@+id/btn_wordResult2"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="评测结果"
                android:layout_gravity="center"
                android:layout_marginLeft="1dp"
                android:background="@drawable/btn_right"
                />
        </LinearLayout>
        <LinearLayout
            android:layout_marginHorizontal="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="1dp"
            >
            <Button
                android:id="@+id/btn_wordTest3"
                android:layout_width="0dp"
                android:layout_weight="2"
                android:layout_height="wrap_content"
                android:text="词义"
                android:layout_gravity="center"
                android:layout_marginRight="1dp"
                android:background="@drawable/btn_left"
                />
            <Button
                android:id="@+id/btn_wordResult3"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="评测结果"
                android:layout_gravity="center"
                android:layout_marginLeft="1dp"
                android:background="@drawable/btn_right"
                />
        </LinearLayout>
        <LinearLayout
            android:layout_marginHorizontal="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="1dp"
            >
            <Button
                android:id="@+id/btn_wordTest4"
                android:layout_width="0dp"
                android:layout_weight="2"
                android:layout_height="wrap_content"
                android:text="非词复述"
                android:layout_gravity="center"
                android:layout_marginRight="1dp"
                android:background="@drawable/btn_left"
                />
            <Button
                android:id="@+id/btn_wordResult4"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="评测结果"
                android:layout_gravity="center"
                android:layout_marginLeft="1dp"
                android:background="@drawable/btn_right"
                />
        </LinearLayout>
    </LinearLayout>




    <LinearLayout
        android:id="@+id/pn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/wd"
        app:layout_constraintBottom_toTopOf="@id/gm"
        >
        <TextView
            android:id="@+id/tv_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="构音"
            android:textColor="@color/black"
            android:textSize="25dp"
            android:background="@color/warm_blue"
            />
        <LinearLayout
            android:layout_marginTop="10dp"
            android:layout_marginHorizontal="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="1dp"
            >
            <Button
                android:id="@+id/btn_pronunciationTest"
                android:layout_width="0dp"
                android:layout_weight="2"
                android:layout_height="wrap_content"
                android:text="构音"
                android:layout_gravity="center"
                android:layout_marginRight="1dp"
                android:background="@drawable/btn_left"
                />
            <Button
                android:id="@+id/btn_pronunciationResult"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="评测结果"
                android:layout_gravity="center"
                android:layout_marginLeft="1dp"
                android:background="@drawable/btn_right"
                />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/gm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/pn"
        app:layout_constraintBottom_toTopOf="@id/nr"
        >
        <TextView
            android:id="@+id/tv_4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="语法理解"
            android:textColor="@color/black"
            android:textSize="25dp"
            android:background="@color/warm_blue"
            />
        <LinearLayout
            android:layout_marginTop="10dp"
            android:layout_marginHorizontal="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="1dp"
            >
            <Button
                android:id="@+id/btn_grammarTest"
                android:layout_width="0dp"
                android:layout_weight="2"
                android:layout_height="wrap_content"
                android:text="语法理解"
                android:layout_gravity="center"
                android:layout_marginRight="1dp"
                android:background="@drawable/btn_left"
                />
            <Button
                android:id="@+id/btn_grammarResult"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="评测结果"
                android:layout_gravity="center"
                android:layout_marginLeft="1dp"
                android:background="@drawable/btn_right"
                />
        </LinearLayout>
    </LinearLayout>


    <LinearLayout
        android:id="@+id/nr"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/gm"
        app:layout_constraintBottom_toTopOf="@id/upload_and_pdf"
        >
        <TextView
            android:id="@+id/tv_5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="叙述"
            android:textColor="@color/black"
            android:textSize="25dp"
            android:background="@color/warm_blue"
            />
        <LinearLayout
            android:layout_marginTop="10dp"
            android:layout_marginHorizontal="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="1dp"
            >
            <Button
                android:id="@+id/btn_narrateTest1"
                android:layout_width="0dp"
                android:layout_weight="2"
                android:layout_height="wrap_content"
                android:text="看图说故事"
                android:layout_gravity="center"
                android:layout_marginRight="1dp"
                android:background="@drawable/btn_left"
                />
            <Button
                android:id="@+id/btn_narrateResult1"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="评测结果"
                android:layout_gravity="center"
                android:layout_marginLeft="1dp"
                android:background="@drawable/btn_right"
                />
        </LinearLayout>
        <LinearLayout
            android:layout_marginHorizontal="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="1dp"
            >
            <Button
                android:id="@+id/btn_narrateTest2"
                android:layout_width="0dp"
                android:layout_weight="2"
                android:layout_height="wrap_content"
                android:text="个人生活经验"
                android:layout_gravity="center"
                android:layout_marginRight="1dp"
                android:background="@drawable/btn_left"
                />
            <Button
                android:id="@+id/btn_narrateResult2"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="评测结果"
                android:layout_gravity="center"
                android:layout_marginLeft="1dp"
                android:background="@drawable/btn_right"
                />
        </LinearLayout>
    </LinearLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/upload_and_pdf"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/nr"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="10dp"
        >


    <Button
        android:id="@+id/btn_upload"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:background="@drawable/btn"
        android:layout_marginHorizontal="10dp"
        app:layout_constraintHorizontal_chainStyle="spread"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_download"
        app:layout_constraintBottom_toBottomOf="parent"
        android:text="上传数据"
        android:layout_gravity="center"
        />
        <Button
            android:id="@+id/btn_download"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="@drawable/btn"
            android:layout_marginHorizontal="10dp"
            app:layout_constraintHorizontal_chainStyle="spread"
            app:layout_constraintStart_toEndOf="@id/btn_upload"
            app:layout_constraintEnd_toStartOf="@id/btn_pdf"
            app:layout_constraintBottom_toBottomOf="parent"
            android:text="本地保存"
            android:layout_gravity="center"
            android:visibility="gone"
            />
    <Button
        android:id="@+id/btn_pdf"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:background="@drawable/btn"
        android:layout_marginHorizontal="10dp"
        android:text="导出PDF"
        android:layout_gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/btn_download"
        app:layout_constraintBottom_toBottomOf="parent"
        />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>




